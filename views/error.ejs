<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>error</title>
  <link rel="stylesheet" href="/css/global.css">
</head>
<body class="card-page">
  <div class="card">
    <h1>error</h1>
    <p><%= message %></p>
