<%- include('../partials/nav', { title: 'calendar', user }) %>

  <div class="page-title"><h2>calendar</h2></div>

  <%# ── Semesters ── %>
  <div class="section">
    <h2>semester starts</h2>

    <% if (semesters.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>semester id</th>
          <th>start date</th>
          <th>author</th>
          <th>status</th>
          <th>actions</th>
        </tr>
      </thead>
      <tbody>
        <% semesters.forEach(s => { %>
        <tr>
          <td><%= s.semester_id %></td>
          <td><%= s.start_date %></td>
          <td><%= s.author %></td>
          <td class="<%= s.is_published ? '' : 'unpublished' %>"><%= s.is_published ? 'published' : 'draft' %></td>
          <td>
            <form action="/dashboard/calendar/semesters/<%= s.id %>/toggle" method="POST" style="display:inline">
              <button class="btn" type="submit"><%= s.is_published ? 'unpublish' : 'publish' %></button>
            </form>
            <form action="/dashboard/calendar/semesters/<%= s.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('delete?')">
              <button class="btn" type="submit">delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
      <p class="unpublished">no semesters yet.</p>
    <% } %>

    <form action="/dashboard/calendar/semesters" method="POST" class="add-form">
      <div class="field">
        <label>semester id</label>
        <input type="text" name="semester_id" placeholder="e.g. 2026L" required>
      </div>
      <div class="field">
        <label>start date</label>
        <input type="date" name="start_date" required>
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <div class="checkbox-row">
          <input type="checkbox" name="is_published" id="sem_pub" value="1">
          <label for="sem_pub">publish</label>
        </div>
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <button type="submit" class="solid">add</button>
      </div>
    </form>
  </div>

  <%# ── Substitutions ── %>
  <div class="section">
    <h2>substitution days</h2>
    <p class="section-note">on the original date, classes are held as if it were the selected weekday.</p>

    <% if (substitutions.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>original date</th>
          <th>taught as</th>
          <th>author</th>
          <th>status</th>
          <th>actions</th>
        </tr>
      </thead>
      <tbody>
        <% substitutions.forEach(s => { %>
        <tr>
          <td><%= s.original_date %></td>
          <td><%= days[s.day_of_week] %> (<%= s.day_of_week %>)</td>
          <td><%= s.author %></td>
          <td class="<%= s.is_published ? '' : 'unpublished' %>"><%= s.is_published ? 'published' : 'draft' %></td>
          <td>
            <form action="/dashboard/calendar/substitutions/<%= s.id %>/toggle" method="POST" style="display:inline">
              <button class="btn" type="submit"><%= s.is_published ? 'unpublish' : 'publish' %></button>
            </form>
            <form action="/dashboard/calendar/substitutions/<%= s.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('delete?')">
              <button class="btn" type="submit">delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
      <p class="unpublished">no substitutions yet.</p>
    <% } %>

    <form action="/dashboard/calendar/substitutions" method="POST" class="add-form">
      <div class="field">
        <label>original date</label>
        <input type="date" name="original_date" required>
      </div>
      <div class="field">
        <label>taught as</label>
        <select name="day_of_week" required>
          <option value="">-- day --</option>
          <option value="1">monday (1)</option>
          <option value="2">tuesday (2)</option>
          <option value="3">wednesday (3)</option>
          <option value="4">thursday (4)</option>
          <option value="5">friday (5)</option>
        </select>
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <div class="checkbox-row">
          <input type="checkbox" name="is_published" id="sub_pub" value="1">
          <label for="sub_pub">publish</label>
        </div>
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <button type="submit" class="solid">add</button>
      </div>
    </form>
  </div>

</body>
</html>
